# PrintFlow Server Configuration
# Copy this to .env and fill in your values

# Server
PORT=3001
SOCKET_PORT=3001
NODE_ENV=development

# Security — CHANGE THESE before first run!
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# Database
DB_PATH=./data/printflow.db

# CORS — comma-separated list of allowed origins
# In production set this to your exact client origins
ALLOWED_ORIGINS=http://localhost:3000,app://printflow

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# ── Bambu Lab LAN Mode ──────────────────────────────────────────
# Printers are registered via the app UI — no config needed here.
# The server connects automatically to all printers in the database.

# ── Canada Post API ─────────────────────────────────────────────
# Register at: https://www.canadapost-postescanada.ca/information/app/developers/
CANADAPOST_USERNAME=your_cp_api_username
CANADAPOST_PASSWORD=your_cp_api_password
CANADAPOST_CUSTOMER_NUMBER=your_customer_number
CANADAPOST_FROM_POSTAL=L9R1A1
CANADAPOST_SANDBOX=true

# ── First-run owner account ─────────────────────────────────────
OWNER_NAME=Owner
OWNER_EMAIL=owner@printflow.local
OWNER_PASSWORD=ChangeMe123!
