{
  "name": "printflow",
  "version": "1.0.35",
  "description": "PrintFlow — 3D Print Business Suite",
  "main": "src/main/main.js",
  "author": "Robert Dunn",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-dev": "ELECTRON_START_URL=http://localhost:3000 electron .",
    "build": "npm run react-build && electron-builder",
    "build:mac": "npm run react-build && electron-builder --mac",
    "build:win": "npm run react-build && electron-builder --win",
    "build:all": "npm run react-build && electron-builder --mac --win",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "date-fns": "^3.3.1",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.2",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.printflow.app",
    "productName": "PrintFlow",
    "copyright": "Copyright © 2026 PrintFlow",
    "extends": null,
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "darkModeSupport": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "generic",
      "url": "http://10.0.0.219:3001/updates/"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
