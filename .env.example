# PrintFlow — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before starting PrintFlow.
# Never commit your .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Secret key used to sign authentication tokens.
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ── Optional ──────────────────────────────────────────────────────────────────

# Port to expose the server on (default: 3001)
SERVER_PORT=3001

# Comma-separated list of allowed CORS origins.
# Leave blank to allow all origins (fine for local network use).
# Example: http://192.168.1.100:3001,http://printflow.local:3001
ALLOWED_ORIGINS=
